<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ===== PROPIEDADES ===== -->
    <property name="LOG_PATH"  value="logs"/>
    <property name="APP_NAME"  value="redsolidaria"/>
    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%-5level) [%thread] %cyan(%logger{36}) - %msg%n"/>

    <!-- ===== APPENDER: CONSOLA con colores ANSI ===== -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ===== APPENDER: ARCHIVO rotativo diario ===== -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/${APP_NAME}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- Rotar cada día, conservar 30 días, comprimir -->
            <fileNamePattern>${LOG_PATH}/${APP_NAME}.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
            <maxHistory>30</maxHistory>
            <totalSizeCap>500MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ===== LOGGER: paquete propio en DEBUG ===== -->
    <logger name="com.redsolidaria.enjambre" level="DEBUG" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>

    <!-- ===== LOGGER: WebSocket específico ===== -->
    <logger name="com.redsolidaria.enjambre.ws" level="DEBUG" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>

    <!-- ===== LOGGER: librerías externas — solo WARN ===== -->
    <logger name="org.springframework"           level="WARN"/>
    <logger name="org.hibernate"                 level="WARN"/>
    <logger name="com.zaxxer.hikari"             level="WARN"/>
    <logger name="org.apache.tomcat"             level="WARN"/>

    <!-- ===== ROOT: INFO por defecto ===== -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>
